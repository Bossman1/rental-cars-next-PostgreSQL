generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS & AUTH ───────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String?
  role          UserRole  @default(STAFF)
  phone         String?
  avatar        String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  rentals  Rental[]
  accounts Account[]
  sessions Session[]

  @@map("users")
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
  CUSTOMER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─── CARS ────────────────────────────────────────────────
model Car {
  id           String      @id @default(cuid())
  make         String
  model        String
  year         Int
  licensePlate String      @unique
  color        String
  category     CarCategory
  status       CarStatus   @default(AVAILABLE)
  pricePerDay  Decimal     @db.Decimal(10, 2)
  mileage      Int         @default(0)
  fuelType     FuelType    @default(PETROL)
  seats        Int         @default(5)
  transmission String      @default("Automatic")
  imageUrl     String?
  description  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  rentals     Rental[]
  maintenance Maintenance[]

  @@map("cars")
}

enum CarCategory {
  ECONOMY
  COMPACT
  SEDAN
  SUV
  LUXURY
  VAN
  TRUCK
}

enum CarStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  RETIRED
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
}

// ─── CUSTOMERS ───────────────────────────────────────────
model Customer {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  email         String    @unique
  phone         String
  driverLicense String    @unique
  licenseExpiry DateTime
  address       String?
  city          String?
  country       String    @default("GE")
  dateOfBirth   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  rentals Rental[]

  @@map("customers")
}

// ─── RENTALS ─────────────────────────────────────────────
model Rental {
  id           String       @id @default(cuid())
  rentalNumber String       @unique @default(cuid())
  customerId   String
  carId        String
  staffId      String
  startDate    DateTime
  endDate      DateTime
  returnedAt   DateTime?
  status       RentalStatus @default(RESERVED)
  totalDays    Int
  pricePerDay  Decimal      @db.Decimal(10, 2)
  totalAmount  Decimal      @db.Decimal(10, 2)
  deposit      Decimal      @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  car      Car      @relation(fields: [carId], references: [id])
  staff    User     @relation(fields: [staffId], references: [id])
  payments Payment[]

  @@map("rentals")
}

enum RentalStatus {
  RESERVED
  ACTIVE
  COMPLETED
  CANCELLED
  OVERDUE
}

// ─── PAYMENTS ────────────────────────────────────────────
model Payment {
  id            String        @id @default(cuid())
  rentalId      String
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())

  rental Rental @relation(fields: [rentalId], references: [id])

  @@map("payments")
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  ONLINE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ─── MAINTENANCE ─────────────────────────────────────────
model Maintenance {
  id          String            @id @default(cuid())
  carId       String
  type        String
  description String
  cost        Decimal?          @db.Decimal(10, 2)
  status      MaintenanceStatus @default(SCHEDULED)
  scheduledAt DateTime
  completedAt DateTime?
  createdAt   DateTime          @default(now())

  car Car @relation(fields: [carId], references: [id])

  @@map("maintenance")
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}